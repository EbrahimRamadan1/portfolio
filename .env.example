# Base URL for the backend API
# Used by the axios client for all API requests
NEXT_PUBLIC_API_BASE_URL=http://localhost:4000/api

# Secret used for signing auth tokens
# Generate with: openssl rand -base64 32
AUTH_SECRET=your-auth-secret-here

# Resend API key for contact form email delivery
RESEND_API_KEY=re_xxxxxxxxxxxx

# Email address to receive contact form submissions
CONTACT_RECEIVER_EMAIL=your@email.com

# From address for sent emails (use your verified domain in Resend)
EMAIL_FROM=onboarding@resend.dev
